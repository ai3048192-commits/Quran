{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    
    /* السماح بالـ JS و JSX */
    "allowJs": true, 
    "checkJs": false,
    "skipLibCheck": true,
    
    /* إعدادات الموديولات */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false, 
    "noImplicitAny": false,
    "moduleDetection": "force",
    "noEmit": true,
    "isolatedModules": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
